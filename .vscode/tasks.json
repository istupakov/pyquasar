{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "uv: ruff format",
            "type": "shell",
            "command": "uv run ruff format",
            "problemMatcher": [],
            "detail": "Format code using Ruff"
        },
        {
            "label": "uv: nbstripout",
            "type": "shell",
            "command": "find . -name '*.ipynb' -exec uv run nbstripout {} +",
            "problemMatcher": [],
            "detail": "Clean Jupyter outputs"
        },
        {
            "label": "uv: ruff check",
            "type": "shell",
            "command": "uv run ruff check",
            "problemMatcher": [],
            "detail": "Lint with Ruff"
        },
        {
            "label": "uv: ty check",
            "type": "shell",
            "command": "uv run ty check",
            "problemMatcher": [],
            "detail": "Type check with ty"
        },
        {
            "label": "uv: build",
            "type": "shell",
            "command": "uv build --clear",
            "dependsOrder": "sequence",
            "dependsOn": [
                "uv: ruff format",
                "uv: nbstripout",
                "uv: ruff check",
                "uv: ty check"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "detail": "Lint and build dist"
        },
        {
            "label": "uv: pytest",
            "type": "shell",
            "command": "uv run pytest --cov",
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "detail": "Run all tests with pytest"
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "find . -type d -name '__pycache__' -exec rm -rf {} +; rm -rf .ruff_cache .pytest_cache dist",
            "windows": {
                "command": "Get-ChildItem -Path . -Recurse -Include '__pycache__','.ruff_cache','.pytest_cache', 'dist' | Remove-Item -Recurse -Force"
            },
            "problemMatcher": [],
            "detail": "Clean caches and build artifacts"
        }
    ]
}
